MySQL example:
DB_TYPE=mysql
DB_URL=jdbc:mysql://192.168.52.238:3306/hrsystem?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=hrsystem
DB_PASSWORD=hrsystem

# PostgreSQL example:
# DB_TYPE=pgsql
# DB_URL=jdbc:postgresql://localhost:5432/autohr
# DB_USERNAME=postgres
# DB_PASSWORD=your_password

# WebRTC relay. deploy-ubuntu.sh installs coturn and writes these values.
# INTERVIEW_STUN_URLS=stun:stun.l.google.com:19302,stun:stun.cloudflare.com:3478
# INTERVIEW_TURN_URLS=turn:your-public-domain-or-ip:3478?transport=udp,turn:your-public-domain-or-ip:3478?transport=tcp
# INTERVIEW_TURN_USERNAME=autohr
# INTERVIEW_TURN_CREDENTIAL=change-this-password
# TURN_HOST=your-public-domain-or-ip
# TURN_USERNAME=autohr
# TURN_CREDENTIAL=change-this-password
# TURN_REALM=autohr.local
# TURN_MIN_PORT=49160
# TURN_MAX_PORT=49200
