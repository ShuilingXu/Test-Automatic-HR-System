# Interview page security:
# INTERVIEW_DISABLE_DEVTOOLS_SHORTCUTS=true

# WebRTC relay. Public Ubuntu deploy auto-detects TURN_HOST and TURN_PRIVATE_IP.
# INTERVIEW_STUN_URLS=stun:stun.l.google.com:19302,stun:stun.cloudflare.com:3478
# For public deploy use the server public IP/domain. For LAN testing use the host LAN IP.
# INTERVIEW_TURN_URLS=turn:your-public-ip-or-domain:3478?transport=udp,turn:your-public-ip-or-domain:3478?transport=tcp
# INTERVIEW_TURN_USERNAME=autohr
# INTERVIEW_TURN_CREDENTIAL=change-this-password
# TURN_HOST=your-public-ip-or-domain
# TURN_EXTERNAL_IP=your-server-public-ip
# TURN_PRIVATE_IP=your-server-private-ip-if-behind-nat
# TURN_USERNAME=autohr
# TURN_CREDENTIAL=change-this-password
# TURN_REALM=autohr.local
# TURN_MIN_PORT=49160
# TURN_MAX_PORT=49200

# Video recording merge. Ubuntu deploy installs ffmpeg and verifies libvpx-vp9/libopus.
# INTERVIEW_VIDEO_FFMPEG_PATH=ffmpeg
# INTERVIEW_VIDEO_VIDEO_CODEC=libvpx-vp9
# INTERVIEW_VIDEO_AUDIO_CODEC=libopus
